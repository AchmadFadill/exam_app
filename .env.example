APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=exam_app
DB_USERNAME=root
DB_PASSWORD=

##############################################################################
# DATABASE – Connection & concurrency tuning for 400 students
# ──────────────────────────────────────────────────────────────────────────
# max_connections (MySQL server variable, set in my.cnf or mysql.conf.d):
#   Minimum recommended for 400 students = php_fpm_pm.max_children × apps
#   Example: 100 FPM workers × 1 app = at least 110 (add 10 % headroom).
#
# DB_PERSISTENT=false  – keep false unless you are on a DEDICATED server.
#   Persistent PDO connections reuse the TCP socket across PHP requests and
#   save ~1-3 ms per request but can exhaust max_connections if pm.max_children
#   is large relative to MySQL's max_connections.
#
# PHP-FPM recommended settings for 400 students (in www.conf):
#   pm = dynamic
#   pm.max_children      = 80   ; never > (RAM_MB - 200) / avg_PHP_worker_MB
#   pm.start_servers     = 20
#   pm.min_spare_servers = 10
#   pm.max_spare_servers = 30
#   pm.max_requests      = 500  ; recycle workers to prevent memory leaks
##############################################################################
DB_PERSISTENT=false

##############################################################################
# SESSION – Database driver (required for 400-student load)
# ──────────────────────────────────────────────────────────────────────────
# FILE driver uses OS flock() which serialises concurrent PHP-FPM workers.
# DATABASE driver uses indexed DB rows – handles 400 concurrent sessions.
#
# After changing SESSION_DRIVER, run:
#   php artisan migrate          (creates the sessions table + indexes)
#   php artisan session:flush    (clears stale file sessions if migrating)
##############################################################################
SESSION_DRIVER=database
# Lifetime should exceed the longest exam duration (minutes).
# Example: 3-hour exam → set at least 180.
SESSION_LIFETIME=180
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
